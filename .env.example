# --- アプリ（FastAPI）---
# development | production（シードや挙動の目安。DATABASE_URL はデプロイ先で切替）
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://dev_user:dev_password@localhost:5432/device_reservation

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=device-reservation

# アプリ API の「管理者」判定: Keycloak アクセストークンの realm_access.roles にこの名前が含まれるか（既定: app-admin）
# KEYCLOAK_APP_ADMIN_REALM_ROLE=app-admin
# 開発シードが上記ロールを付与するレルムユーザー名（既定: admin）
# KEYCLOAK_SEED_GRANT_APP_ADMIN_USERNAME=admin

# 開発シード（python -m app.seeding）が Keycloak Admin API でクライアントを自動設定するときの管理者
# （未設定時は admin / admin。compose の KEYCLOAK_ADMIN と揃える）
# KEYCLOAK_SEED_ADMIN_USERNAME=admin
# KEYCLOAK_SEED_ADMIN_PASSWORD=admin
# 開発シードが Keycloak に作成するダミー利用者 8 名の共通パスワード（既定: SeedUsersDev1!）
# KEYCLOAK_SEED_USER_PASSWORD=

APP_HOST=0.0.0.0
APP_PORT=8000

# --- MinIO（装置画像。compose.dev.yml で :9000 を公開）---
# MINIO_ENDPOINT_URL=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=device-images
# DEVICE_IMAGE_MAX_BYTES=2097152

# --- 依存コンテナ起動（scripts/compose.sh / just deps-up）---
# development（既定）: Keycloak は dev-file + 名前付きボリューム（compose.dev.yml）。コンテナ再作成でも KC 設定は保持。
# production: Keycloak を Postgres の keycloak DB に JDBC 接続（compose.prod.yml）。アプリ DB と同一 Postgres サーバ。
# 切替前は just deps-down（または prod 用 down）推奨。詳細は doc/local-development.md。
PERSISTENCE_PROFILE=development
